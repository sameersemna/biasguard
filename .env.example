# ============================================================
# BiasGuard Environment Configuration
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# ── LLM Configuration ──────────────────────────────────────
# Primary provider: anthropic | openai | groq | xai
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# Fallback provider (used if primary fails)
FALLBACK_LLM_PROVIDER=groq
FALLBACK_LLM_MODEL=llama-3.1-70b-versatile

# ── LLM API Keys ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...
XAI_API_KEY=xai-...

# ── Embeddings ─────────────────────────────────────────────
EMBEDDING_PROVIDER=openai                    # openai | nomic | huggingface
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Vector Database ────────────────────────────────────────
VECTOR_DB=chroma                             # chroma | pinecone
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=bias_patterns

# Pinecone (if VECTOR_DB=pinecone)
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=biasguard

# ── API Configuration ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_DEBUG=false
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# ── Observability ──────────────────────────────────────────
# LangSmith (https://smith.langchain.com)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=biasguard-prod
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Arize Phoenix
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
PHOENIX_ENABLED=true

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                             # json | text
LOG_FILE=./logs/biasguard.log

# ── Report Generation ──────────────────────────────────────
REPORTS_DIR=./data/outputs
PDF_GENERATION_ENABLED=true

# ── Frontend ───────────────────────────────────────────────
STREAMLIT_API_BASE_URL=http://localhost:8000

# ── Feature Flags ──────────────────────────────────────────
ENABLE_ASYNC_PROCESSING=false
ENABLE_CACHING=true
CACHE_TTL_SECONDS=3600
