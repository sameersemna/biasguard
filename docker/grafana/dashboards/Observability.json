  "templating": {
    "list": [
      {
        "name": "doc_type",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(biasguard_analysis_duration_seconds_count, doc_type)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "provider",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(biasguard_llm_calls_total, provider)",
